# Shopify credentials
SHOPIFY_SHOP_NAME=your-store.myshopify.com
SHOPIFY_API_VERSION=2025-07
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- LLM provider selection ----
# LLM_PROVIDER can be "gemini" or "openai"
LLM_PROVIDER=gemini

# Gemini (required when LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# ---- Server config ----
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Agent tuning ----
AGENT_MAX_ITERATIONS=12
AGENT_TEMPERATURE=0.2
SHOPIFY_MAX_PAGES=10
SHOPIFY_DEFAULT_PAGE_SIZE=100
SHOPIFY_REQUEST_TIMEOUT_SECONDS=30
