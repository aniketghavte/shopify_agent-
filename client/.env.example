# Where the client should send API calls.
# In dev we proxy /api/* via Vite to this target (see vite.config.ts).
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# If you deploy the client separately (e.g. on Vercel), set this to the
# absolute backend URL and the client will talk to it directly.
# VITE_API_BASE_URL=https://shopify-agent-api.example.com
